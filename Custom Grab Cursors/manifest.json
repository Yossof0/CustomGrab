{
  "manifest_version": 3,
  "name": "Custom Grab Cursors",
  "version": "1.1",
  "description": "Transform any page's grab/grabbing cursor into stylish custom images with flexible hotspots, color accents and easy configuration.",
  "icons": {
    "16": "resources/icon16.png",
    "48": "resources/icon48.png",
    "128": "resources/icon128.png"
  },
  "permissions": ["storage"],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["resources/grab.png", "resources/grabbing.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
